generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  hashedPassword  String
  role            String         @default("USER") // USER | ADMIN
  avatar          String?
  isApproved      Boolean        @default(true) // For self-registration flow
  approvedAt      DateTime?
  requestQuota    Int            @default(0)    // Max requests per quota period (0 = unlimited)
  requestQuotaDays Int           @default(7)    // Quota period in days
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  requests        Request[]
  activities      Activity[]
  notifications   Notification[]
  invitesCreated  Invite[]
}

model Platform {
  id       Int     @id @default(autoincrement())
  slug     String  @unique
  name     String
  igdbId   Int?
  rommId   Int?
  icon     String?
  games    Game[]
}

model Game {
  id          Int       @id @default(autoincrement())
  igdbId      Int?      // Not unique alone — same IGDB game can exist per platform
  name        String
  summary     String?
  coverUrl    String?
  releaseDate String?
  rating      Float?
  platformId  Int
  platform    Platform  @relation(fields: [platformId], references: [id])
  rommId      Int?      // ID in the RomM library if available
  isAvailable Boolean   @default(false)
  requests    Request[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([igdbId, platformId]) // One Game row per (igdbGame, platform) pair
  @@index([platformId])
  @@index([name])
}

model Request {
  id         Int        @id @default(autoincrement())
  status     String     @default("PENDING") // PENDING | APPROVED | DECLINED | AVAILABLE | DOWNLOADING | CANCELLED
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  gameId     Int
  game       Game       @relation(fields: [gameId], references: [id])
  comment    String?
  adminNote  String?    // Admin note (e.g. decline reason)
  downloads  Download[]
  activities Activity[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([userId, gameId])
  @@index([status])
}

model Settings {
  id                    Int     @id @default(1)
  rommUrl               String  @default("")
  rommApiKey            String  @default("")
  rommUsername           String  @default("")
  rommPassword          String  @default("")
  igdbClientId          String  @default("")
  igdbClientSecret      String  @default("")
  qbitUrl               String  @default("")
  qbitUsername           String  @default("")
  qbitPassword          String  @default("")
  qbitCategory          String  @default("rommseer")
  qbitSavePath          String  @default("")
  prowlarrUrl           String  @default("")
  prowlarrApiKey        String  @default("")
  prowlarrAutoGrab      Boolean @default(false)
  prowlarrSearchTemplate String @default("{game_name} {platform} ROM")
  prowlarrMinSeeders    Int     @default(1)
  prowlarrMaxSizeMb     Int     @default(0)
  prowlarrPreferredIndexers String @default("")
  prowlarrSkipFailingIndexers Boolean @default(true)
  stallDetectEnabled    Boolean @default(true)
  stallDetectMinutes    Int     @default(30)
  sabnzbdUrl            String  @default("")
  sabnzbdApiKey         String  @default("")
  sabnzbdCategory       String  @default("rommseer")
  autoApprove           Boolean @default(false)
  rommLibraryPath       String  @default("") // Path to RomM library root accessible by Rommseer (e.g. /romm/library)
  discordWebhookUrl     String  @default("")
  notifyOnRequest       Boolean @default(true)
  notifyOnApprove       Boolean @default(true)
  notifyOnDecline       Boolean @default(true)
  notifyOnAvailable     Boolean @default(true)
  notifyOnFailed        Boolean @default(true)
  librarySyncHours      Int     @default(6) // How often to sync RomM library (0 = disabled)
  prowlarrDryRun        Boolean @default(false) // Log auto-grab results without downloading
  torrentEnabled        Boolean @default(true)  // Allow torrent downloads via qBittorrent
  usenetEnabled         Boolean @default(true)  // Allow usenet downloads via SABnzbd
  archiveOrgEnabled     Boolean @default(false) // Search & download directly from Internet Archive
  downloadPriority      String  @default("torrent,usenet,ia") // Comma-separated order: torrent,usenet,ia
  registrationEnabled   Boolean @default(false) // Allow self-registration
  initialized           Boolean @default(false)
}

model Download {
  id           Int      @id @default(autoincrement())
  requestId    Int
  request      Request  @relation(fields: [requestId], references: [id])
  downloadType String   @default("torrent") // "torrent" | "usenet"
  torrentHash  String?
  torrentName  String?
  magnetUrl    String?
  nzbId        String?  // SABnzbd NZO ID for usenet downloads
  indexer      String?  // Prowlarr indexer name (for failure tracking)
  stalledAt    DateTime? // When stall was first detected (for stallDetectMinutes timer)
  status       String   @default("PENDING") // PENDING | DOWNLOADING | COMPLETED | FAILED
  progress     Float    @default(0)
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([requestId])
  @@index([torrentHash])
  @@index([nzbId])
  @@index([status])
}

model Activity {
  id         Int      @id @default(autoincrement())
  type       String   // REQUEST_CREATED | APPROVED | DECLINED | CANCELLED | DOWNLOAD_STARTED | DOWNLOAD_COMPLETED | DOWNLOAD_FAILED | DOWNLOAD_STALLED | AVAILABLE | RETRY
  message    String
  metadata   String?  // JSON string for extra data
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  requestId  Int?
  request    Request? @relation(fields: [requestId], references: [id])
  downloadId Int?
  createdAt  DateTime @default(now())

  @@index([requestId])
  @@index([createdAt])
  @@index([type])
}

model IndexerHealth {
  indexer       String   @id
  failureCount  Int      @default(0)
  lastFailure   DateTime?
  blockedUntil  DateTime?
  updatedAt     DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // REQUEST_APPROVED | REQUEST_DECLINED | DOWNLOAD_FAILED | AVAILABLE
  message   String
  link      String?  // e.g. /requests
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model Invite {
  token       String    @id @default(cuid())
  email       String?   // Optional: restrict to specific email
  usedAt      DateTime?
  usedBy      String?   // User ID who redeemed
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([createdById])
}
